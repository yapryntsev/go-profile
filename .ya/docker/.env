ENV=dev

APP_NAME=goph-profile
APP_HTTP_ADDR=:8080
APP_JWT_SECRET=secret
APP_JWT_TTL=1h
APP_DB_CONNECT=postgresql://goph-profile@db:5432/goph-profile?sslmode=disable
APP_S3_ADDR=minio:9000
APP_S3_ACCESS_KEY_ID=goph-profile
APP_S3_SECRET_ACCESS_KEY=goph-profile
APP_S3_BUCKET_NAME=goph-profile
APP_KAFKA_ADDR=kafka:9092
APP_KAFKA_TOPIC=resize

SERVER_PORT=8080
WORKER_PORT=8081
DB_PORT=5432
KAFKA_PORT=9092

POSTGRES_USER=goph-profile
POSTGRES_PASSWORD=goph-profile
POSTGRES_DB=goph-profile

MINIO_API_PORT=9000
MINIO_ADM_PORT=9001
MINIO_USER=goph-profile
MINIO_PASSWORD=goph-profile

OTEL_SERVICE_NAME=goph-profile
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=${ENV}
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_EXPORTER_OTLP_INSECURE=true